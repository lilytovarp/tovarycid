generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuotationStatus {
  NEW
  REVIEWED
  QUOTED
  ACCEPTED
  REJECTED
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String      @id @default(cuid())
  slug        String      @unique
  nameEn      String
  nameEs      String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  quotations  Quotation[]
}

model Quotation {
  id           String          @id @default(cuid())
  serviceId    String
  service      Service         @relation(fields: [serviceId], references: [id])
  clientName   String
  email        String
  phone        String
  companyName  String?
  details      String
  heardFrom    String?
  status       QuotationStatus @default(NEW)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}
